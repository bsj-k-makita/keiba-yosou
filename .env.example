# JRA odds API base URL (required for --source=jra)
JRA_ODDS_API_BASE_URL="https://example.com/api/odds"

# Optional auth headers
# JRA_ODDS_API_TOKEN="your-bearer-token"
# JRA_ODDS_API_KEY="your-x-api-key"

# Optional endpoint path template (replaces {raceId})
# Example: JRA_ODDS_API_BASE_URL=https://example.com
#          JRA_ODDS_API_ENDPOINT_TEMPLATE=/api/odds/{raceId}
# JRA_ODDS_API_ENDPOINT_TEMPLATE="/api/odds/{raceId}"

# Optional rows path in JSON response
# Example response: { "data": { "rows": [...] } }
# JRA_ODDS_API_ROWS_PATH="data.rows"
